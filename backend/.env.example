# =====================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this to .env or set in your deployment platform
# =====================================================

# Database (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Settings → Database → Connection string (JDBC)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_supabase_db_password

# Profile: use "local" for dev, "prod" for production
SPRING_PROFILES_ACTIVE=local

# JWT — CHANGE THIS IN PRODUCTION (use a random 64+ char hex string)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# File uploads
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10MB

# CORS — set to your frontend URL
FRONTEND_URL=http://localhost:5173

# =====================================================
# AI / OpenRouter — Get your key from: https://openrouter.ai/keys
# Uses free Llama 3 model — $0 cost!
# =====================================================
AI_API_KEY=sk-or-v1-your-openrouter-key-here
# Optional overrides:
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_CHAT_MODEL=meta-llama/llama-3.2-3b-instruct:free
